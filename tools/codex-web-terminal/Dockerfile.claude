FROM node:20-alpine

ENV CLAUDE_INSTALL_ROOT=/opt/claude-code \
  PATH=/opt/claude-code/.local/bin:$PATH \
  USE_BUILTIN_RIPGREP=0 \
  DISABLE_AUTOUPDATER=1

RUN apk add --no-cache git bash openssh-client ripgrep curl libgcc libstdc++ \
  && mkdir -p "$CLAUDE_INSTALL_ROOT" \
  && export HOME="$CLAUDE_INSTALL_ROOT" \
  && curl -fsSL https://claude.ai/install.sh | bash \
  && test -x "$CLAUDE_INSTALL_ROOT/.local/bin/claude" \
  && "$CLAUDE_INSTALL_ROOT/.local/bin/claude" --version >/dev/null \
  && chmod -R a+rX "$CLAUDE_INSTALL_ROOT"

RUN addgroup claude \
  && adduser -D -G claude -h /home/claude claude \
  && mkdir -p /workspace \
  && chown -R claude:claude /home/claude /workspace

WORKDIR /workspace
USER claude

# Interactive image: the AgentSwarm server spawns `docker run ... <image> sh -lc <startScript>`.
CMD ["bash"]
