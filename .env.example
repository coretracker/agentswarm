# Bootstrap admin account used only on first creation.
DEFAULT_ADMIN_NAME=Administrator
DEFAULT_ADMIN_EMAIL=admin@agentswarm.local
DEFAULT_ADMIN_PASSWORD=admin123!
AUTH_COOKIE_NAME=agentswarm_session
AUTH_SESSION_TTL_DAYS=7
GIT_USER_NAME=AgentSwarm Bot
GIT_USER_EMAIL=agentswarm@local.dev
# Optional but recommended for deployed Docker setups. Must be an absolute host path.
# TASK_WORKSPACE_HOST_ROOT=/absolute/path/to/agentswarm/task-workspaces
PUBLIC_PORT=3217
CORS_ORIGIN=http://localhost:3217

# Leave blank to use the bundled same-origin proxy at /api.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SOCKET_URL=

# Optional interactive terminal images for browser-launched Codex / Claude Code sessions.
CODEX_INTERACTIVE_IMAGE=local/codex-interactive:latest
CLAUDE_INTERACTIVE_IMAGE=local/claude-interactive:latest

# Credentials are configured in the AgentSwarm Settings page.
